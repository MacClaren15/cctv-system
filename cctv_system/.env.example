# CCTV System Environment Variables
# Copy to .env and update with your values

# Flask Configuration
SECRET_KEY=your-secure-secret-key-here
DEBUG=False

# API Configuration
API_KEY=your-api-key-here
ENABLE_AUTH=False

# Email Configuration (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=cctv-system@example.com

# Slack Configuration (for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Database Configuration
DATABASE_URL=sqlite:///./data/cctv_system.db
DATABASE_BACKUP_PATH=./data/backups

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./data/logs/cctv_system.log

# Performance Configuration
MAX_THREADS=4
FRAME_SKIP=1
BUFFER_SIZE=100

# Camera Configuration
DEFAULT_CAMERA_INDEX=0
DEFAULT_CAMERA_RESOLUTION=1280x720
DEFAULT_CAMERA_FPS=30

# Motion Detection Configuration
MOTION_SENSITIVITY=0.3
MOTION_MIN_AREA=500

# Object Detection Configuration
OBJECT_DETECTION_MODEL=yolov8m
OBJECT_DETECTION_DEVICE=cpu
OBJECT_CONFIDENCE_THRESHOLD=0.5

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=False

# Notification Settings
ALERT_ENABLED=True
ALERT_COOLDOWN=60
EMAIL_ALERTS=False
SLACK_ALERTS=False

# Recording Settings
RECORDING_ENABLED=True
RECORDING_PATH=./data/recordings
RECORDING_PRE_SECONDS=10
RECORDING_POST_SECONDS=30

# System Settings
DATA_RETENTION_DAYS=30
AUTO_CLEANUP_ENABLED=True
AUTO_CLEANUP_INTERVAL=3600
